{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mythera",
  "version": "1.0.10",
  "identifier": "com.mythera.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mythera",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Mythera Minecraft Launcher",
    "longDescription": "Mythera Minecraft Launcher",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
